# --- LLM API Keys ---
GOOGLE_API_KEY=your_google_ai_studio_key
OPENAI_API_KEY=your_openai_key

# --- Langfuse Monitoring ---
LANGFUSE_PUBLIC_KEY=your_public_key
LANGFUSE_SECRET_KEY=your_secret_key
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Storage (MinIO/S3) ---
S3_ENDPOINT_URL=http://minio:9000
S3_ACCESS_KEY=admin
S3_SECRET_KEY=password123
S3_BUCKET_NAME=automation-evidence
S3_REGION=us-east-1
S3_PUBLIC_URL_PREFIX=http://localhost:9000/automation-evidence

# --- Messaging (Redis) ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
